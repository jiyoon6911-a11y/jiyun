rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Guestbook collection matches
    match /guestbook/{messageId} {
      allow read: if true;
      allow create: if isValidMessage();
      allow update, delete: if false;
    }

    function isValidMessage() {
      let data = request.resource.data;
      return data.keys().hasAll(['text', 'author', 'createdAt'])
        && data.keys().size() == 3
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 500
        && data.author is string
        && data.author.size() > 0
        && data.author.size() <= 100
        && data.createdAt is string
        && data.createdAt.size() <= 60;
    }
  }
}
